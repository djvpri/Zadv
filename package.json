{
  "name": "zadv",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build && cp -r .next/static .next/standalone/.next/static && (cp -r public .next/standalone/public 2>/dev/null || true)",
    "start": "node scripts/migrate.js && node .next/standalone/server.js",
    "lint": "next lint",
    "seed": "node scripts/seed-apps.js",
    "update:zone": "node scripts/update-zone.js",
    "electron:dev": "electron .",
    "electron:build": "node scripts/build-electron.js",
    "electron:pack": "electron-builder --win portable --x64 --dir"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@vercel/og": "0.6.5",
    "bcryptjs": "2.4.3",
    "busboy": "^1.6.0",
    "jose": "5.9.6",
    "next": "15.5.9",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/busboy": "^1.5.4",
    "@types/node": "22.9.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "10.4.20",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.9",
    "postcss": "8.4.47",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.14",
    "tsx": "^4.23.0",
    "typescript": "5.6.3"
  },
  "build": {
    "appId": "id.zomet.zadv",
    "productName": "Zadv",
    "asar": false,
    "forceCodeSigning": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**",
      ".next/standalone/**",
      "!.next/standalone/node_modules/.cache/**",
      "!**/*.map"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "Zadv-portable-${version}.exe",
      "sign": null,
      "signingHashAlgorithms": null
    }
  }
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PromoApp {
  id        Int      @id @default(autoincrement())
  nama      String
  emoji     String
  tagline   String
  fitur     String[]
  accent    String
  tint      String
  url       String?
  aktif     Boolean  @default(true)
  urutan    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  kontens   KontenPromo[]
  videoJobs VideoJob[]
}

model KontenPromo {
  id        Int      @id @default(autoincrement())
  appId     Int
  app       PromoApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  tipe      String   // 'caption' | 'poster'
  platform  String?  // 'instagram' | 'whatsapp' | 'facebook' (khusus caption)
  tone      String?
  teks      String?  // isi caption (khusus tipe caption)
  createdAt DateTime @default(now())

  @@index([appId])
  @@index([createdAt])
}

model VideoJob {
  id           Int      @id @default(autoincrement())
  appId        Int?
  app          PromoApp? @relation(fields: [appId], references: [id], onDelete: SetNull)
  caption      String   // teks overlay yang diminta (sebelum sanitasi)
  status       String   @default("pending") // pending | processing | done | error
  errorMessage String?
  inputPath    String   // path video asli di volume
  outputPath   String?  // path hasil olahan, terisi kalau status=done
  durasiAsli   Float?   // detik, terisi setelah ffprobe jalan
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
}
